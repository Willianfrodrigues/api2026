{
  "version": 2,
  "builds": [
    { "src": "api/auth.py",                    "use": "@vercel/python" },
    { "src": "api/manage.py",                  "use": "@vercel/python" },
    { "src": "api/sync.py",                    "use": "@vercel/python" },
    { "src": "api/fields.py",                  "use": "@vercel/python" },
    { "src": "api/cron/run.py",                "use": "@vercel/python" },
    { "src": "api/oauth/meta/start.py",        "use": "@vercel/python" },
    { "src": "api/oauth/meta/callback.py",     "use": "@vercel/python" },
    { "src": "api/oauth/tiktok/start.py",      "use": "@vercel/python" },
    { "src": "api/oauth/tiktok/callback.py",   "use": "@vercel/python" },
    { "src": "api/oauth/dv360/start.py",       "use": "@vercel/python" },
    { "src": "api/oauth/dv360/callback.py",    "use": "@vercel/python" },
    { "src": "api/oauth/kwai/start.py",        "use": "@vercel/python" },
    { "src": "api/oauth/kwai/callback.py",     "use": "@vercel/python" },
    { "src": "index.html",                     "use": "@vercel/static" }
  ],
  "crons": [
    { "path": "/api/cron/run", "schedule": "0 3 * * *" }
  ],
  "routes": [
    { "src": "/api/auth/(.*)",                "dest": "/api/auth.py" },
    { "src": "/api/fields",                   "dest": "/api/fields.py" },
    { "src": "/api/connections(.*)",          "dest": "/api/manage.py" },
    { "src": "/api/destinations/test",         "dest": "/api/manage.py" },
    { "src": "/api/destinations(.*)",          "dest": "/api/manage.py" },
    { "src": "/api/tablegroups(.*)",           "dest": "/api/manage.py" },
    { "src": "/api/tables(.*)",                "dest": "/api/manage.py" },
    { "src": "/api/transfers(.*)",             "dest": "/api/manage.py" },
    { "src": "/api/logs(.*)",                  "dest": "/api/manage.py" },
    { "src": "/api/sync",                      "dest": "/api/sync.py" },
    { "src": "/api/cron/run",                  "dest": "/api/cron/run.py" },
    { "src": "/api/oauth/meta/start",          "dest": "/api/oauth/meta/start.py" },
    { "src": "/api/oauth/meta/callback",       "dest": "/api/oauth/meta/callback.py" },
    { "src": "/api/oauth/tiktok/start",        "dest": "/api/oauth/tiktok/start.py" },
    { "src": "/api/oauth/tiktok/callback",     "dest": "/api/oauth/tiktok/callback.py" },
    { "src": "/api/oauth/dv360/start",         "dest": "/api/oauth/dv360/start.py" },
    { "src": "/api/oauth/dv360/callback",      "dest": "/api/oauth/dv360/callback.py" },
    { "src": "/api/oauth/kwai/start",          "dest": "/api/oauth/kwai/start.py" },
    { "src": "/api/oauth/kwai/callback",       "dest": "/api/oauth/kwai/callback.py" },
    { "src": "/(.*)",                          "dest": "/index.html" }
  ]
}
